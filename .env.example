# Angel Doctor environment example
# Copy this file to .env.local for local development.
# Do not commit real secrets or production credentials.

# Site
NEXT_PUBLIC_SITE_URL="https://www.angeldoctor.com"
NEXT_PUBLIC_SITE_NAME="Angel Doctor"
NEXT_PUBLIC_SITE_LOCALE="en"

# Contact
NEXT_PUBLIC_CONTACT_EMAIL="marketing@jumper-medical.com"
NEXT_PUBLIC_WHATSAPP_NUMBER="+86 185 6670 0732"
NEXT_PUBLIC_WHATSAPP_URL="https://wa.me/8618566700732"

# Analytics placeholders
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED="false"

# Supabase lead storage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Resend email notifications + user auto-reply
RESEND_API_KEY=""
EMAIL_FROM="Angel Doctor <onboarding@resend.dev>"
LEAD_NOTIFY_EMAIL="marketing@jumper-medical.com"

# Phase 2 Stripe placeholders
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CARE_PLAN_PAYMENT_LINK=""
STRIPE_ESCORT_PAYMENT_LINK=""

# Optional operational placeholders
NEXT_PUBLIC_SUPPORT_TIMEZONE="Asia/Shanghai"
NEXT_PUBLIC_DEFAULT_COUNTRY="China"
