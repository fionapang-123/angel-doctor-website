# Angel Doctor environment example
# Copy this file to .env.local for local development.
# Do not commit real secrets or production credentials.

# Site
NEXT_PUBLIC_SITE_URL="https://www.angeldoctor.com"
NEXT_PUBLIC_SITE_NAME="Angel Doctor"
NEXT_PUBLIC_SITE_LOCALE="en"

# Contact
NEXT_PUBLIC_CONTACT_EMAIL="contact@example.com"
NEXT_PUBLIC_WHATSAPP_URL="https://wa.me/000000000000"

# Analytics placeholders
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED="false"

# Phase 2 Supabase placeholders
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Phase 2 Stripe placeholders
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CARE_PLAN_PAYMENT_LINK=""
STRIPE_ESCORT_PAYMENT_LINK=""

# Optional email and form handling placeholders
FORM_ENDPOINT=""
FORMSPREE_ENDPOINT=""
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_TO=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# Optional operational placeholders
NEXT_PUBLIC_SUPPORT_TIMEZONE="Asia/Shanghai"
NEXT_PUBLIC_DEFAULT_COUNTRY="China"
